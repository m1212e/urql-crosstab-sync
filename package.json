{
  "name": "@m1212e/urql-crosstab-sync",
  "module": "./out/index.mjs",
  "version": "0.1.0",
  "type": "module",
  "description": "A urql exchange that mirrors mutations and query results between same-origin browser tabs over BroadcastChannel, keeping graphcache state (including optimistic updates) in sync.",
  "keywords": [
    "urql",
    "exchange",
    "graphcache",
    "broadcastchannel",
    "crosstab",
    "cross-tab",
    "sync",
    "graphql"
  ],
  "author": "m1212e",
  "repository": "https://github.com/m1212e/urql-crosstab-sync",
  "homepage": "https://github.com/m1212e/urql-crosstab-sync#readme",
  "bugs": "https://github.com/m1212e/urql-crosstab-sync/issues",
  "files": [
    "out",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "license": "Apache-2.0",
  "scripts": {
    "format": "bun run lint",
    "lint": "bunx biome check --write .",
    "build": "tsdown",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.1",
    "lefthook": "^2.1.9",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@urql/core": "^6",
    "wonka": "^6"
  },
  "main": "./out/index.cjs",
  "types": "./out/index.d.cts",
  "exports": {
    ".": {
      "import": "./out/index.mjs",
      "require": "./out/index.cjs"
    },
    "./package.json": "./package.json"
  }
}
